#!/usr/bin/env bash
# Git native post-commit hook — append each commit to PROGRESS.md history.
#
# Runs after every successful commit (via core.hooksPath=.githooks). It stamps the
# commit number, date, subject and file count into the "Historique des commits"
# section of PROGRESS.md, giving a continuous, resumable project log. The narrative
# sections (Reste à faire, État) are maintained by hand.
#
# The appended line lands in the working tree (it is not part of the commit just
# made) and is then staged, so it rides along with the next commit even when that
# commit stages only specific files. No auto-amend (that would be unsafe).
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || exit 0)"
progress="$repo_root/PROGRESS.md"
[[ -f "$progress" ]] || exit 0

short="$(git rev-parse --short HEAD)"

# Idempotent: skip if this commit is already logged (e.g. hook fired twice).
if grep -qF -- "\`$short\`" "$progress"; then
  exit 0
fi

date="$(git log -1 --pretty=%cd --date=format:'%Y-%m-%d')"
subject="$(git log -1 --pretty=%s)"
files="$(git show --pretty=format: --name-only HEAD | grep -c . || true)"

# shellcheck disable=SC2016  # backticks/%s are printf format literals, not expansions
printf -- '- `%s` %s — %s _(%s fichiers)_\n' "$short" "$date" "$subject" "$files" >> "$progress"

# Stage the appended line so it is committed with the next commit, even one that
# stages only specific files. Best-effort: never fail the (already-made) commit.
git add -- "$progress" 2>/dev/null || true

# Re-arm the pre-commit review gate: clear the approval marker so the NEXT commit
# must re-run the full review (defence-in-depth on top of the staged-diff-hash key).
rm -f "$(git rev-parse --git-dir)/claude-simplify-ok" 2>/dev/null || true
