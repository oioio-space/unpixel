#!/usr/bin/env bash
# Git native pre-commit hook (deterministic gates).
# Installed via `git config core.hooksPath .githooks`, so it is versioned and fires for
# everyone on every `git commit`.
#
# Four gates, in order:
#   0. Repo janitor — tidy regenerable artifacts + block any staged artifact.
#   1. Secret scan (gitleaks) on staged changes — block leaks before they exist.
#   2. Code vuln scan (gosec + govulncheck) on staged Go — block insecure code.
#   3. Google Go style-guide gate (gofmt/vet/golangci-lint/build/test) on staged Go.
# A non-zero exit from any of them aborts the commit.
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"

# Prefer the mise task (pinned tool versions); fall back to the raw script/binary.
use_mise=0
if command -v mise >/dev/null 2>&1 && [[ -f "$repo_root/mise.toml" ]]; then use_mise=1; fi
mise_or() { # $1 = mise task, rest = fallback command
  local task="$1"
  shift
  if [[ $use_mise -eq 1 ]]; then mise run "$task"; else "$@"; fi
}

# gate <header> <fail-msg> <mise-task> <fallback-cmd...>
gate() {
  local header="$1" fail="$2" task="$3"
  shift 3
  printf '\033[34m▶ %s\033[0m\n' "$header"
  if ! mise_or "$task" "$@"; then
    printf '\033[31m✗ %s\033[0m\n' "$fail" >&2
    printf '  (To bypass in an emergency only: git commit --no-verify)\n' >&2
    exit 1
  fi
}

gate "Tidying artifacts (repo-janitor)…" \
  "Commit blocked: build/scan artifacts are staged (see above)." \
  "clean:check" "$repo_root/scripts/clean-artifacts.sh" --check

gate "Scanning staged changes for secrets (gitleaks)…" \
  "Commit blocked: a secret was detected in the staged changes. Remove/rotate it." \
  "scan:secrets:staged" gitleaks git --staged --redact

gate "Scanning staged Go for vulnerabilities (gosec + govulncheck)…" \
  "Commit blocked: a security vulnerability was found. Fix it or annotate //nolint:gosec." \
  "scan:code:staged" "$repo_root/scripts/sec-scan.sh" --staged

gate "Running Google Go style-guide checks…" \
  "Commit blocked: fix the style-guide violations above." \
  "lint:staged" "$repo_root/scripts/lint.sh" --staged

gate "Checking the project stays pure Go (no CGO)…" \
  "Commit blocked: CGO is forbidden in this project (see CLAUDE.md)." \
  "cgo:check" "$repo_root/scripts/cgo-check.sh"
