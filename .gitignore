# Binaries
/unpixel
*.exe
*.test
*.out

# Coverage / test reports
coverage.*
junit.xml

# goreleaser output
/dist/

# SBOM artifact (regenerated by `mise run sbom`)
sbom.cdx.json

# Benchmark / profiling artifacts
bench-*.txt
*.prof
# Recovery panel: the latest run is regenerable; quality-baseline.json is committed.
benchmarks/quality-latest.json
# Journal: per-run JSON snapshots are regenerable; docs/JOURNAL.md is tracked.
benchmarks/journal/*.json

# mise local overrides (per-machine, not shared)
mise.local.toml
.mise.local.toml

# Wild fixtures: downloaded images are gitignored; manifest.json is tracked.
testdata/wild/*.png
testdata/wild/*.jpg

# OS / editor
.DS_Store
